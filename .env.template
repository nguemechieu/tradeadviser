################################################################################
# TradeAdviser - Environment Configuration Template
# 
# Copy this file to .env and update the values as needed for your environment.
# 
# Environment-Specific Sections:
#   - Common Configuration: Shared across all deployments
#   - PostgreSQL Configuration: Database settings
#   - Backend API Configuration: FastAPI/backend settings
#   - Desktop Application Configuration: Desktop UI settings
#   - Docker Compose Configuration: Container runtime settings
################################################################################

################################################################################
# COMMON CONFIGURATION
################################################################################

# Application environment (development, staging, production)
APP_ENV=development

# Application name
APP_NAME=TradeAdviser

# Log level (debug, info, warning, error, critical)
LOG_LEVEL=info

# Enable debug mode (true/false)
APP_DEBUG=true


################################################################################
# POSTGRESQL DATABASE CONFIGURATION
################################################################################

# PostgreSQL host (use 'postgres' for Docker, 'localhost' for local development)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database name
POSTGRES_DB=tradeadviser

# Database user credentials
POSTGRES_USER=tradeadviser
POSTGRES_PASSWORD=tradeadviser_dev_password

# Full connection strings (auto-generated from above if not specified)
# DATABASE_URL=postgresql+psycopg://tradeadviser:tradeadviser_dev_password@postgres:5432/tradeadviser
# ASYNC_DATABASE_URL=postgresql+asyncpg://tradeadviser:tradeadviser_dev_password@postgres:5432/tradeadviser


################################################################################
# BACKEND API CONFIGURATION
################################################################################

# API host and port (use 'backend' for Docker, 'localhost' for local)
API_HOST=0.0.0.0
API_PORT=8000

# API base URL (used by frontend to connect to backend)
API_URL=http://localhost:8001
API_BASE_URL=/api/v1

# WebSocket URL (used by frontend for real-time updates)
WS_URL=ws://localhost:8001/ws
WS_BASE_URL=/ws

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:6080,http://localhost:5900,http://localhost:8001,http://localhost:3000

# Enable CORS credentials
CORS_ALLOW_CREDENTIALS=true


################################################################################
# TRADING CREDENTIALS & ACCOUNTS
################################################################################

# Trading platform credentials (base64 encoded for security)
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# COINBASE_PASSPHRASE=

# Trading mode (paper, sandbox, live)
TRADING_MODE=paper

# Default account ID
DEFAULT_ACCOUNT_ID=

# Enable trading (true/false) - set to false for live mode caution
ENABLE_TRADING=false

# Risk management settings
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=500.00
STOP_LOSS_PERCENT=2.0
TAKE_PROFIT_PERCENT=5.0


################################################################################
# MARKET DATA CONFIGURATION
################################################################################

# Market data provider (coinbase, alpaca, etc.)
MARKET_DATA_PROVIDER=coinbase

# Historical data retention (days)
HISTORICAL_DATA_RETENTION_DAYS=365

# Real-time data update interval (seconds)
REALTIME_UPDATE_INTERVAL=1

# Enable market hours only mode
MARKET_HOURS_ONLY=true


################################################################################
# DESKTOP APPLICATION CONFIGURATION
################################################################################

# Desktop mode (GUI, HTTP)
DESKTOP_MODE=GUI

# Enable hybrid desktop (combined desktop + API)
ENABLE_HYBRID_DESKTOP=1

# HTTP UI specific
HTTP_UI=0
DISABLE_WEBENGINE=0

# Virtual display settings for HTTP mode
DISPLAY=:99
SCREEN_WIDTH=1600
SCREEN_HEIGHT=900
SCREEN_DEPTH=24
SCREEN_DPI=96

# VNC settings (for HTTP/browser access)
VNC_PORT=5900
NOVNC_PORT=6080
NOVNC_RESIZE_MODE=off
NOVNC_RECONNECT=1
NOVNC_SHOW_DOT=1
NOVNC_TLS_ENABLED=0
NOVNC_TLS_HOSTNAME=localhost

# Desktop app HTTP port
APP_HTTP_PORT=6080

# UI theme (dark, light, auto)
UI_THEME=dark

# Enable notifications
ENABLE_NOTIFICATIONS=true

# Desktop cache directory
DESKTOP_CACHE_DIR=./data/cache


################################################################################
# DOCKER COMPOSE CONFIGURATION
################################################################################

# Container registry
DOCKER_REGISTRY=ghcr.io

# Image versions
PYTHON_VERSION=3.11
POSTGRES_IMAGE_VERSION=15-alpine

# Container port mappings
POSTGRES_PORT_HOST=5433
API_PORT_HOST=8001
APP_HTTP_PORT_HOST=6080
VNC_PORT_HOST=5900

# Docker compose profiles to enable
# Uncomment to enable: web, dev, monitoring
DOCKER_PROFILES=

# Build arguments
BUILD_ENVIRONMENT=development
BUILD_OPTIMIZATION_LEVEL=0


################################################################################
# MONITORING & LOGGING
################################################################################

# Enable monitoring
ENABLE_MONITORING=true

# Log file location
LOG_FILE_PATH=./logs/tradeadviser.log

# Log rotation settings
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Enable request logging
LOG_REQUESTS=true

# Performance profiling
ENABLE_PROFILING=false


################################################################################
# SECURITY SETTINGS
################################################################################

# Session timeout (seconds)
SESSION_TIMEOUT=3600

# Password minimum requirements
PASSWORD_MIN_LENGTH=8

# Enable SSL/TLS
USE_SSL=false

# SSL certificate paths (if enabled)
# SSL_CERT_PATH=
# SSL_KEY_PATH=


################################################################################
# FEATURE FLAGS
################################################################################

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable advanced risk management
ENABLE_ADVANCED_RISK_MANAGEMENT=true

# Enable portfolio analytics
ENABLE_PORTFOLIO_ANALYTICS=true

# Enable backtesting
ENABLE_BACKTESTING=true

# Enable live trading alerts
ENABLE_LIVE_TRADING_ALERTS=false


################################################################################
# EXTERNAL SERVICE INTEGRATIONS
################################################################################

# Optional: Slack notifications
# SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=

# Optional: Email notifications
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# NOTIFICATION_EMAIL=

# Optional: Discord notifications
# DISCORD_WEBHOOK_URL=

# Optional: Telegram notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=


################################################################################
# DEVELOPMENT SETTINGS (development environment only)
################################################################################

# Enable hot reload
ENABLE_HOT_RELOAD=true

# Enable debug logging
ENABLE_DEBUG_LOGGING=true

# Enable mock data
ENABLE_MOCK_DATA=true

# Mock data seed
MOCK_DATA_SEED=42

# Enable API documentation
ENABLE_API_DOCS=true

# Enable testing mode
TESTING_MODE=false


################################################################################
# ADVANCED CONFIGURATION
################################################################################

# Database connection pooling
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# API request timeout (seconds)
API_REQUEST_TIMEOUT=30

# API rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=3600

# Backtest configuration
BACKTEST_WORKERS=4
BACKTEST_CHUNK_SIZE=1000

# Cache configuration
CACHE_BACKEND=memory
CACHE_TTL=3600

# Message queue
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
