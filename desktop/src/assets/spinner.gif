/span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>info(</span><br><span>            </span><span class="ͼr">f"📊 AvgConf=</span><span>{</span><span class="ͼt">avg_conf</span><span>:</span><span class="ͼn">.3f</span><span>}</span><span class="ͼr"> | WeakCount=</span><span>{</span><span class="ͼt">self</span><span class="ͼn">.</span><span>low_confidence_count}</span><span class="ͼr">"</span><br><span>        )</span><br><br><span>    </span><span class="ͼl"># ----------------------------------------------------------</span><br><span>    </span><span class="ͼl"># AUTO TRAINING</span><br><span>    </span><span class="ͼl"># ----------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">auto_train_if_needed</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">force</span><span class="ͼn">=</span><span class="ͼq">False</span><span>):</span><br><br><span>        </span><span class="ͼn">try</span><span>:</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼt">force</span><span> </span><span class="ͼn">and</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>low_confidence_count </span><span class="ͼn">&lt;</span><span> </span><span class="ͼq">5</span><span>:</span><br><span>                </span><span class="ͼn">return</span><br><br><span>            </span><span class="ͼt">signal_file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">f"./src/data/signal_</span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">.csv"</span><br><span>            </span><span class="ͼt">candle_file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">f"./src/data/</span><span>{</span><span class="ͼt">symbol</span><span>}</span><span cla