</span><span>:</span><br><span>        </span><span class="ͼn">return</span><br><br><span>    </span><span class="ͼt">broker</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">creds</span><span>[</span><span class="ͼr">"broker"</span><span>]</span><br><br><span>    </span><span class="ͼt">self</span><span class="ͼn">.</span><span>exchange_type_box</span><span class="ͼn">.</span><span>setCurrentText(</span><span class="ͼt">broker</span><span>[</span><span class="ͼr">"type"</span><span>])</span><br><span>    </span><span class="ͼt">self</span><span class="ͼn">.</span><span>exchange_box</span><span class="ͼn">.</span><span>setCurrentText(</span><span class="ͼt">broker</span><span>[</span><span class="ͼr">"exchange"</span><span>])</span><br><br><span>    </span><span class="ͼt">self</span><span class="ͼn">.</span><span>api_input</span><span class="ͼn">.</span><span>setText(</span><span class="ͼt">broker</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"api_key"</span><span>, </span><span class="ͼr">""</span><span>))</span><br><span>    </span><span class="ͼt">self</span><span class="ͼn">.</span><span>secret_input</span><span class="ͼn">.</span><span>setText(</span><span class="ͼt">broker</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"secret"</span><span>, </span><span class="ͼr">""</span><span>))</span><br><br><span>    </span><span class="ͼt">self</span><span class="ͼn">.</span><span>mode_box</span><span class="ͼn">.</span><span>setCurrentText(</span><span class="ͼt">broker</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"mode"</span><span>, </span><span class="ͼr">"paper"</span><span>))</span><br><br><span>    </span><span class="ͼt">self</span><span class="ͼn">.</span><span>risk_input</span><span class="ͼn">.</span><span>setValue(</span><br><span>        </span><span class="ͼt">creds</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"risk"</span><span>, {})</span><span class="