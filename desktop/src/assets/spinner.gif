"requests&gt;=2.31",</span></code></pre><p><span>]</span></p><p><span><span data-placeholder-token="true" class="text-token-text-primary cursor-text rounded-sm" style="background-color: color-mix(in srgb, var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">[project.optional-dependencies]</span></span></p><p><span>dev = [</span><br><span>"black",</span><br><span>"ruff",</span><br><span>"pytest"</span><br><span>]</span></p><p><span><span data-placeholder-token="true" class="text-token-text-primary cursor-text rounded-sm" style="background-color: color-mix(in srgb, var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">[tool.setuptools.packages.find]</span></span><br><span>where = <span data-placeholder-token="true" class="text-token-text-primary cursor-text rounded-sm" style="background-color: color-mix(in srgb, var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">["src"]</span></span></p><p><span><span data-placeholder-token="true" class="text-token-text-primary cursor-text rounded-sm" style="background-color: color-mix(in srgb, var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">[tool.black]</span></span><br><span>line-length = 100</span></p><p><span><span data-placeholder-token="true" class="text-token-text-primary cursor-text rounded-sm" style="background-color: color-mix(in srgb, var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">[tool.ruff]</span></span><br><span>line-length = 100</span></p></div></div></div>
<hr data-start="1214" data-end="1217">
<h1 data-section-id="qnx6dj" data-start="1219" data-end="1251">⚠️ Important Things This Fixes</h1>
<h3 data-section-id="180biul" data-start="1253" data-end="1281">1️⃣ Locks Python version</h3>
<pre class="overflow-visible! px-0!" data-start="1282" data-end="1326"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#e45ab3" fill="currentColor"></use></svg>TOML</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>requires-python = "&gt;=3.10,&lt;3.12"</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="1328" data-end="1358">This prevents installing with:</p>
<p data-start="1360" data-end="1391">❌ Python 3.13<br data-start="1373" data-end="1376">
❌ Python 3.14</p>
<p data-start="1393" data-end="1428">Those cause <strong data-start="1405" data-end="1427">TensorFlow crashes</strong>.</p>
<hr data-start="1430" data-end="1433">
<h3 data-section-id="1owmbzk" data-start="1435" data-end="1471">2️⃣ Removes problematic packages</h3>
<p data-start="1472" data-end="1494">We <strong data-start="1475" data-end="1493">do not include</strong>:</p>
<ul data-start="1496" data-end="1539">
<li data-section-id="1wpz2xj" data-start="1496" data-end="1507">
<p data-start="1498" data-end="1507"><code data-start="1498" data-end="1507">pyaudio</code></p>
</li>
<li data-section-id="n5rk7" data-start="1508" data-end="1521">
<p data-start="1510" data-end="1521"><code data-start="1510" data-end="1521">portaudio</code></p>
</li>
<li data-section-id="vg1zzy" data-start="1522" data-end="1539">
<p data-start="1524" data-end="1539">unstable wheels</p>
</li>
</ul>
<p data-start="1541" data-end="1581">Those caused your earlier build failure.</p>
