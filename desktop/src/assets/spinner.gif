an class="ͼt">candle_path</span><span>)</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼt">signal_data</span><span class="ͼn">.</span><span>shape[</span><span class="ͼq">1</span><span>] </span><span class="ͼn">&lt;</span><span> </span><span class="ͼq">4</span><span>:</span><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_log_error(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼr">"Signal data must have ≥4 columns"</span><span>)</span><br><span>                </span><span class="ͼn">return</span><span> </span><span class="ͼq">False</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼt">len</span><span>(</span><span class="ͼt">signal_data</span><span>) </span><span class="ͼn">&lt;</span><span> </span><span class="ͼq">50</span><span>:</span><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_log_warn(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼr">"Not enough data to train"</span><span>)</span><br><span>                </span><span class="ͼn">return</span><span> </span><span class="ͼq">False</span><br><br><span>            </span><span class="ͼl"># --- Get previous loss ---</span><br><span>            </span><span class="ͼt">prev_loss</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_get_recent_loss(</span><span class="ͼt">order_history_path</span><span>)</span><br><br><span>            </span><span class="ͼl"># --- Build features ---</span><br><span>            </span><span class="ͼt">features</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">signal_data</span><span class="ͼn">.</span><span>iloc[</span><span class="ͼn">-</span><span class="ͼq">200</span><span>:]</span><span class="ͼn">.</span><span>copy()</span><br><br><span>            </span><span class="ͼt">features</span><span>[</span><span class="ͼr">"open"</span><span>] </span><span class="ͼn">=</span><span> </span><span class="ͼt">candle_data</span><span class="ͼn">.</span><span>iloc[</span><span class="ͼn">-</span><span class="ͼq">200</span><span>:, </span><span class="ͼq">1</span><span>]</span><span class="ͼn">.</span><span>values</span><br><span>            </span><span class="ͼt">features</span><span>[</span><span class="ͼr">"close"</span><span>] </span><span class="ͼn">=</span><span> </span><span class="ͼt">candle_data</span><span class="ͼn">.</span><span>iloc[</span><span class="ͼn">-</span><span class="ͼq">200</span><span>:, </span><span class="ͼq">2</span><span>]</span><span class="ͼn">.</span><span>values</span><br><span>            </span><span class="ͼt">features</span><span>[</span><span class="ͼr">"prev_loss"</span><span>] </span><span class="ͼn">=</span><span> </span><span class="ͼt">prev_loss</span><br><br><span>            </span><span class="ͼt">X</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">features</span><span class="ͼn">.</span><span>values</span><br><br><span>            </span><span class="ͼl"># --- Label: bullish candle ---</span><br><span>            </span><span class="ͼt">y</span><span> </span><span class="ͼn">=</span><span> (</span><span class="ͼt">candle_data</span><span class="ͼn">.</span><span>iloc[</span><span class="ͼn">-</span><span class="ͼq">200</span><span>:, </span><span class="ͼq">2</span><span>] </span><span class="ͼn">&gt;</span><span> </span><span class="ͼt">candle_data</span><span class="ͼn">.</span><span>iloc[</span><span class="ͼn">-</span><span class="ͼq">200</span><span>:, </span><span class="ͼq">1</span><span>])</span><span class="ͼn">.</span><span>astype(</span><span class="ͼt">int</span><span>)</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_log_info(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼr">f"Input shape: </span><s