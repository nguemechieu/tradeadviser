an class="ͼt">metrics</span><span> </span><span class="ͼn">import</span><span> </span><span class="ͼt">accuracy_score</span><br><br><span class="ͼn">from</span><span> </span><span class="ͼt">xgboost</span><span> </span><span class="ͼn">import</span><span> </span><span class="ͼt">XGBClassifier</span><br><br><br><span class="ͼn">class</span><span> </span><span class="ͼs">MT4Trainer</span><span>:</span><br><span>    </span><span class="ͼr">"""</span><br><span class="ͼr">    MT4Trainer trains and saves an XGBoost model to predict direction</span><br><span class="ͼr">    using signal data (RSI, EMA, MACD, etc.) and contextual features.</span><br><span class="ͼr">    """</span><br><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">__init__</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">controller</span><span class="ͼn">=</span><span class="ͼq">None</span><span>):</span><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller </span><span class="ͼn">=</span><span> </span><span class="ͼt">controller</span><br><br><span>    </span><span class="ͼl"># ===============================================================</span><br><span>    </span><span class="ͼl"># MAIN TRAINING ROUTINE</span><br><span>    </span><span class="ͼl"># ===============================================================</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">train_and_save_model</span><span>(</span><br><span>        </span><span class="ͼt">self</span><span>,</span><br><span>        </span><span class="ͼt">symbol</span><span>: </span><span class="ͼt">str</span><span>,</span><br><span>        </span><span class="ͼt">signal_path</span><span>: </span><span class="ͼt">str</span><span>,</span><br><span>        </span><span class="ͼt">candle_path</span><span>: </span><span class="ͼt">str</span><span>,</span><br><span>        </span><span class="ͼt">model_path</span><span>: