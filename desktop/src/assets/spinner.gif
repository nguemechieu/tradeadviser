n><span>strategy</span><span class="ͼn">.</span><span>generate_signal(</span><span class="ͼt">candles</span><span>)</span><br><br><span>                </span><span class="ͼn">if</span><span> </span><span class="ͼt">signal</span><span>:</span><br><br><span>                    </span><span class="ͼn">await</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>execution_manager</span><span class="ͼn">.</span><span>execute(</span><br><span>                        </span><span class="ͼt">symbol</span><span class="ͼn">=</span><span class="ͼt">self</span><span class="ͼn">.</span><span>symbol,</span><br><span>                        </span><span class="ͼt">side</span><span class="ͼn">=</span><span class="ͼt">signal</span><span>[</span><span class="ͼr">"side"</span><span>],</span><br><span>                        </span><span class="ͼt">amount</span><span class="ͼn">=</span><span class="ͼt">signal</span><span>[</span><span class="ͼr">"amount"</span><span>],</span><br><span>                        </span><span class="ͼt">price</span><span class="ͼn">=</span><span class="ͼt">signal</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"price"</span><span>)</span><br><span>                    )</span><br><br><span>                </span><span class="ͼn">await</span><span> </span><span class="ͼt">asyncio</span><span class="ͼn">.</span><span>sleep(</span><span class="ͼq">2</span><span>)</span><br><br><span>            </span><span class="ͼn">except</span><span> </span><span class="ͼt">Exception</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">e</span><span>:</span><br><span>                </span><span class="ͼt">print</span><span>(</span><span class="ͼr">f"Worker error </span><span>{</span><span class="ͼt">self</span><span class="ͼn">.</span><span>symbol}</span><span class="ͼr">: </span><span>{</span><span class="ͼt">e</span><span>}</span><span class="ͼr">"</span><span>)</span></div></div></div></div></div></div></