        # =========================
        # SYSTEM SETTINGS
        # =========================

        self.timeframe ="1d"
        self.limit =1000



        self.running = False

        self.logger.info("Sopotek Trading System initialized")

    # ==========================================
    # START SYSTEM
    # ==========================================

    async def start(self):
        self.logger.info("Connecting broker...")
        await self.broker.connect()
        self.symbols = self.broker.fetch_symbols()
        self.logger.info(f"Loaded {len(self.symbols)} symbols {self.symbols}" )

        self.running = True

        await self.run()

    # ==========================================
    # MAIN TRADING LOOP
    # ==========================================

    async def run(self):

        self.logger.info("Trading loop started")

        while self.running:
            try:
                for symbol in self.symbols[:50]:  # limit symbols for now
                    candles = await self.broker.fetch_ohlcv(
                        symbol,
                        timeframe=self.timeframe,
                        limit=self.limit
                    )
                    signal = self.strategy.generate_signal(candles)
                    if signal:
                        await self.process_signal(symbol, signal)

                await asyncio.sleep(5)

            except Exception as e:

                self.logger.exception("Trading loop error",e.args)

    # ==========================================
    # PROCESS SIGNAL
    # ==========================================

    async def process_signal(self, symbol, signal):

        side = signal["side"]
        price = signal.get("price")
        amount = signal["amount"]

        # Risk validation
        allowed = self.risk_engine.validate_trade(symbol, amount)

        if not allowed:
            self.logger.warning("Trade rejected by risk engine")
            return

        # Execute order
        order = await (self.execution_manager.execute(
            symbol=symbol,
            side=side,
            amount=amount,
            price=price ))

        # Update portfolio
        self.portfolio.update(order)

    # ==========================================
    # STOP SYSTEM
    # ==========================================

    async def stop(self):

        self.logger.info("Stopping trading system")

        self.running = False

