>            </span><span class="ͼn">if</span><span> </span><span class="ͼt">os</span><span class="ͼn">.</span><span>path</span><span class="ͼn">.</span><span>exists(</span><span class="ͼt">model_path</span><span>):</span><br><span>                </span><span class="ͼt">os</span><span class="ͼn">.</span><span>remove(</span><span class="ͼt">model_path</span><span>)</span><br><br><span>            </span><span class="ͼl"># --- Build XGBoost model ---</span><br><span>            </span><span class="ͼt">model</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">XGBClassifier</span><span>(</span><br><span>                </span><span class="ͼt">n_estimators</span><span class="ͼn">=</span><span class="ͼq">300</span><span>,</span><br><span>                </span><span class="ͼt">max_depth</span><span class="ͼn">=</span><span class="ͼq">6</span><span>,</span><br><span>                </span><span class="ͼt">learning_rate</span><span class="ͼn">=</span><span class="ͼq">0.05</span><span>,</span><br><span>                </span><span class="ͼt">subsample</span><span class="ͼn">=</span><span class="ͼq">0.8</span><span>,</span><br><span>                </span><span class="ͼt">colsample_bytree</span><span class="ͼn">=</span><span class="ͼq">0.8</span><span>,</span><br><span>                </span><span class="ͼt">random_state</span><span class="ͼn">=</span><span class="ͼq">42</span><span>,</span><br><span>                </span><span class="ͼt">use_label_encoder</span><span class="ͼn">=</span><span class="ͼq">False</span><span>,</span><br><span>                </span><span class="ͼt">eval_metric</span><span class="ͼn">=</span><span class="ͼr">"logloss"</span><br><span>            )</span><br><br><span>            </span><span class="ͼl"># --- Train model ---</span><br><span>            </span><span class="ͼt">model</span><span class="ͼn">.</span><span>fit(</span><span class="ͼt">X_train</span><span>, </span><span class="ͼt">y_train</span><span>)</span><br><br><span>            </span><span class="ͼl"># --- Evaluate ---</span><br><span>            </span><span class="ͼt">preds</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">model</span><span class="ͼn">.</span><span>predict(</span><span class="ͼt">X_test</span><span>)</span><br><span>            </span><span class="ͼt">acc</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">accuracy_score</span><span>(</span><span class="ͼt">y_test</span><span>, </span><span class="ͼt">preds</span><span>)</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_log_info(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼr">f"Validation accuracy → </span><span>{</span><span class="ͼt">acc</span><span>:</span><span class="ͼn">.3f</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>            </span><span class="ͼl"># --- Save model ---</span><br><span>            </span><span class="ͼt">joblib</span><span class="ͼn">.</span><span>dump(</span><span class="ͼt">model</span><span>, </span><span class="ͼt">model_path</span><span>)</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_log_info(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼr">f"Model saved → </span><span>{</span><span class="ͼt">model_path</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>            </span><span class="ͼl"># --- Save metrics ---</span><br><span>            </span><span class="ͼt">metrics</span><span> </span><span class="ͼn">=</span><span> {</span><br><span>                </span><span class="ͼr">"accuracy"</span><span>: </span><span class="ͼt">acc</span><span>,</span><br><span>                </span><span class="ͼr">"timestamp"</span><span>: </span><span class="ͼt">datetime</span><span class="ͼn">.</span><span>datetime</span><span class="ͼn">.</span><span>now()</span><span class="ͼn">.</span><span>isoformat()</span><br><span>            }</span><br><br><span>            </span><span class="ͼt">pd</span><span class="ͼn">.</span><span>DataFrame([</span><span class="ͼt">metrics</span><span>])</span><span class="ͼn">.</span><span>to_csv(</span><br><span>                </span><span class="ͼr">f"./src/logs/</span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">_training_metrics.csv"</span><span>,</span><br><span>                </span><span class="ͼt">index</span><span class="ͼn">=</span><span class="ͼq">False</span><br><span>            )</span><br><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼq">True</span><br><br><span>        </span><span class="ͼn">except</span><span> </span><span class="ͼt">Exception</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">e</span><span>:</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_log_error(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼr">f"Training failed → </span><span>{</span><span class="ͼt">e</span><span>}</span><span class="ͼr">"</span><span>)</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼq">False</span><br><br><span>    </span><span class="ͼl"># ===============================================================</span><br><span>    </span><span class="ͼl"># UTILITIES</span><br><span>    </span><span class="ͼl"># ===============================================================</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_get_recent_loss</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">path</span><span>: </span><span class="ͼt">str</span><span>) -&gt; </span><span class="ͼt">float</span><span>:</span><br><br><span>        </span><span class="ͼn">try</span><span>:</span><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼt">os</span><span class="ͼn">.</span><span>path</span><span class="ͼn">.</span><span>exists(</span><span class="ͼt">path</span><span>):</span><br><span>                </span><span class="ͼn">return</span><span> </span><span class="ͼq">0.0</span><br><br><span>            </span><span class="ͼt">df</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">pd</span><span class="ͼn">.</span><span>read_csv(</span><span class="ͼt">path</span><span>)</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼt">df</span><span class="ͼn">.</span><span>empty </span><span class="ͼn">or</span><span> </span><span class="ͼr">"profit"</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼn">in</span><span> </span><span class="ͼt">df</span><span class="ͼn">.</span><span>columns:</span><br><span>                </span><span class="ͼn">return</span><span> </span><span class="ͼq">0.0</span><br><br><span>            </span><span class="ͼt">last_pnl</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">float</span><span>(</span><span class="ͼt">df</span><span>[</span><span class="ͼr">"profit"</span><span>]</span><span class="ͼn">.</span><span>iloc[</span><span class="ͼn">-</span><span class="ͼq">1</span><span>])</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼt">np</span><span class="ͼn">.</span><span>clip(</span><span class="ͼt">last_pnl</span><span>, </span><span class="ͼn">-</span><span class="ͼq">100.0</span><span>, </span><span class="ͼq">100.0</span><span>)</span><br><br><span>        </span><span class="ͼn">except</span><span> </span><span class="ͼt">Exception</span><span>:</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼq">0.0</span><br><br><span>    </span><span class="ͼl"># ===============================================================</span><br><span>    </span><span class="ͼl"># LOGGING</span><br><span>    </span><span class="ͼl"># ===============================================================</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_log_info</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">msg</span><span>):</span><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller </span><span class="ͼn">and</span><span> </span><span class="ͼt">hasattr</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller, </span><span class="ͼr">"logger"</span><span>):</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>info(</span><span class="ͼr">f"[</span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">] </span><span>{</span><span class="ͼt">msg</span><span>}</span><span class="ͼr">"</span><span>)</span><br><span>        </span><span class="ͼn">else</span><span>:</span><br><span>            </span><span class="ͼt">print</span><span>(</span><span class="ͼr">f"[INFO] </span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">: </span><span>{</span><span class="ͼt">msg</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_log_warn</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">msg</span><span>):</span><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller </span><span class="ͼn">and</span><span> </span><span class="ͼt">hasattr</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller, </span><span class="ͼr">"logger"</span><span>):</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>warning(</span><span class="ͼr">f"[</span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">] </span><span>{</span><span class="ͼt">msg</span><span>}</span><span class="ͼr">"</span><span>)</span><br><span>        </span><span class="ͼn">else</span><span>:</span><br><span>            </span><span class="ͼt">print</span><span>(</span><span class="ͼr">f"[WARN] </span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">: </span><span>{</span><span class="ͼt">msg</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_log_error</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">msg</span><span>):</span><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller </span><span class="ͼn">and</span><span> </span><span class="ͼt">hasattr</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller, </span><span class="ͼr">"logger"</span><span>):</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">f"[</span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">] </span><span>{</span><span class="ͼt">msg</span><span>}</span><span class="ͼr">"</span><span>)</span><br><span>        </span><span class="ͼn">else</span><span>:</span><br><span>            </span><span class="ͼt">print</span><span>(</span><span class="ͼr">f"[ERROR] </span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">: </span><span>{</span><span class="ͼt">msg</span><span>}</span><span class="ͼr">"</span><span>)</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="5779" data-end="5782">
<h1 data-section-id="1b5x2gj" data-start="5784" data-end="5813">How the Model Is Used Later</h1>
<p data-start="5815" data-end="5837">Load model and scaler:</p>
<pre class="overflow-visible! px-0!" data-start="5839" data-end="6002"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#e45ab3" fill="currentColor"></use></svg>Python</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#ce3544" fill="currentColor"></use></svg></button><button class="btn relative group-focus-within/dialog:focus-visible:[outline-width:1.5px] group-focus-within/dialog:focus-visible:[outline-offset:2.5px] group-focus-within/dialog:focus-visible:[outline-style:solid] group-focus-within/dialog:focus-visible:[outline-color:var(--text-primary)] btn-ghost border-token-border-default ms-2 border font-sans" aria-label="Run code" type="button"><div class="flex w-full items-center justify-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-label="" class="-ms-0.5 icon"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#6ef7a4" fill="currentColor"></use></svg>Run</div></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼt">model</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">joblib</span><span class="ͼn">.</span><span>load(</span><span class="ͼr">"model.pkl"</span><span>)</span><br><span class="ͼt">scaler</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">joblib</span><span class="ͼn">.</span><span>load(</span><span class="ͼr">"scaler.pkl"</span><span>)</span><br><br><span class="ͼt">X_scaled</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">scaler</span><span class="ͼn">.</span><span>transform(</span><span class="ͼt">features</span><span>)</span><br><span class="ͼt">prob</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">model</span><span class="ͼn">.</span><span>predict_proba(</span><span class="ͼt">X_scaled</span><span>)[</span><span class="ͼq">0</span><span>][</span><span class="ͼq">1</span><span>]</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="6004" data-end="6017">Signal logic:</p>
<pre class="overflow-visible! px-0!" data-start="6019" data-end="6131"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#e45ab3" fill="currentColor"></use></svg>Python</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#ce3544" fill="currentColor"></use></svg></button><button class="btn relative group-focus-within/dialog:focus-visible:[outline-width:1.5px] group-focus-within/dialog:focus-visible:[outline-offset:2.5px] group-focus-within/dialog:focus-visible:[outline-style:solid] group-focus-within/dialog:focus-visible:[outline-color:var(--text-primary)] btn-ghost border-token-border-default ms-2 border font-sans" aria-label="Run code" type="button"><div class="flex w-full items-center justify-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-label="" class="-ms-0.5 icon"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#6ef7a4" fill="currentColor"></use></svg>Run</div></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">if</span><span> </span><span class="ͼt">prob</span><span> </span><span class="ͼn">&gt;</span><span> </span><span class="ͼq">0.65</span><span>:</span><br><span>    </span><span class="ͼt">signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"BUY"</span><br><span class="ͼn">elif</span><span> </span><span class="ͼt">prob</span><span> </span><span class="ͼn">&lt;</span><span> </span><span class="ͼq">0.35</span><span>:</span><br><span>    </span><span class="ͼt">signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"SELL"</span><br><span class="ͼn">else</span><span>:</span><br><span>    </span><span class="ͼt">signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"HOLD"</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="6133" data-end="6136">
<h1 data-section-id="9dc0po" data-start="6138" data-end="6178">Why XGBoost Is Perfect for Your MT4 AI</h1>
<p data-start="6180" data-end="6318">✔ Works great with <strong data-start="6199" data-end="6217">indicator data</strong><br data-start="6217" data-end="6220">
✔ No TensorFlow dependency problems<br data-start="6255" data-end="6258">
✔ Fast training<br data-start="6273" data-end="6276">
✔ Easy to deploy in your <strong data-start="6301" data-end="6318">PredictServer</strong></p>
<p data-start="6320" data-end="6345">Typical trading pipeline:</p>
<pre class="overflow-visible! px-0!" data-start="6347" data-end="6465"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>MT4</span><br><span> ↓</span><br><span>Indicators (RSI EMA MACD)</span><br><span> ↓</span><br><span>Feature builder</span><br><span> ↓</span><br><span>XGBoost model</span><br><span> ↓</span><br><span>BUY / SELL probability</span><br><span> ↓</span><br><span>Trade signal</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="6467" data-end="6470">
<p data-start="6472" data-end="6544">If you want, I can also help you build the <strong data-start="6515" data-end="6543">next part of your system</strong>:</p>
<h3 data-section-id="1ykzs60" data-start="6546" data-end="6574">MT4 AI Prediction Engine</h3>
