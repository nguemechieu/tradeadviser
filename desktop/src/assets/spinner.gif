"ͼl"># SIGNALS</span><br><span>    </span><span class="ͼl"># =========================================================</span><br><br><span>    </span><span class="ͼt">symbols_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">str</span><span>, </span><span class="ͼt">list</span><span>)</span><br><span>    </span><span class="ͼt">candle_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">str</span><span>, </span><span class="ͼt">object</span><span>)</span><br><span>    </span><span class="ͼt">equity_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">float</span><span>)</span><br><br><span>    </span><span class="ͼt">trade_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">dict</span><span>)</span><br><span>    </span><span class="ͼt">ticker_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">str</span><span>, </span><span class="ͼt">float</span><span>, </span><span class="ͼt">float</span><span>)</span><br><span>    </span><span class="ͼt">connection_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">str</span><span>)</span><br><span>    </span><span class="ͼt">orderbook_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">str</span><span>, </span><span class="ͼt">list</span><span>, </span><span class="ͼt">list</span><span>)</span><br><br><span>    </span><span class="ͼt">strategy_debug_signal</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Signal</span><span>(</span><span class="ͼt">dict</span><span>)</span><br><span>    