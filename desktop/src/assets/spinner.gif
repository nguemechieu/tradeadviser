r><span class="ͼr">    Features:</span><br><span class="ͼr">    - GPT explanation</span><br><span class="ͼr">    - caching</span><br><span class="ͼr">    - self-reflection learning</span><br><span class="ͼr">    - outcome tracking</span><br><span class="ͼr">    - risk scoring</span><br><span class="ͼr">    - performance statistics</span><br><span class="ͼr">    ===============================================================</span><br><span class="ͼr">    """</span><br><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">__init__</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">controller</span><span class="ͼn">=</span><span class="ͼq">None</span><span>,</span><br><span>                 </span><span class="ͼt">log_path</span><span class="ͼn">=</span><span class="ͼr">"./src/logs/reasoning_log.jsonl"</span><span>,</span><br><span>                 </span><span class="ͼt">cache_path</span><span class="ͼn">=</span><span class="ͼr">"./src/logs/reasoning_cache.json"</span><span>):</span><br><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller </span><span class="ͼn">=</span><span> </span><span class="ͼt">controller</span><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>api_key </span><span class="ͼn">=</span><span> </span><span class="ͼt">getattr</span><span>(</span><span class="ͼt">controller</span><span>, </span><span class="ͼr">"api_key"</span><span>, </span><span class="ͼq">None</span><span>)</span><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>client </span><span class="ͼn">=</span><span> </span><span class="ͼt">OpenAI</span><span>(</span><span class="ͼt">api_key</span><span class="ͼn">=</span><span class="ͼt">self</span><span class="ͼn">.</span><span>api_key) </span><span class="ͼn">if</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>api_key </span><span class="ͼn">else</span><span> </span><span class="ͼq">None</span><br><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>log_path </span><span class="ͼn">=</span><span> </span><span class="ͼt">log_path</span><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache_path </span><span class="ͼn">=</span><span> </span><span class="ͼt">cache_path</span><br><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_lock </span><span class="ͼn">=</span><span> </span><span class="ͼt">threading</span><span class="ͼn">.</span><span>Lock()</span><br><br><span>        </span><span class="ͼt">os</span><span class="ͼn">.</span><span>makedirs(</span><span class="ͼt">os</span><span class="ͼn">.</span><span>path</span><span class="ͼn">.</span><span>dirname(</span><span class="ͼt">log_path</span><span>), </span><span class="ͼt">exist_ok</span><span class="ͼn">=</span><span class="ͼq">True</span><span>)</span><br><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache </span><span class="ͼn">=</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_load_cache()</span><br><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller </span><span class="ͼn">and</span><span> </span><span class="ͼt">hasattr</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller, </span><span class="ͼr">"logger"</span><span>):</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger </span><span class="ͼn">=</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>controller</span><span class="ͼn">.</span><span>logger</span><br><span>        </span><span class="ͼn">else</span><span>:</span><br><span>            </span><span class="ͼn">import</span><span> </span><span class="ͼt">logging</span><br><span>            </span><span class="ͼt">logging</span><span class="ͼn">.</span><span>basicConfig(</span><span class="ͼt">level</span><span class="ͼn">=</span><span class="ͼt">logging</span><span class="ͼn">.</span><span>INFO)</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger </span><span class="ͼn">=</span><span> </span><span class="ͼt">logging</span><span class="ͼn">.</span><span>getLogger(</span><span class="ͼr">"ReasoningEngine"</span><span>)</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># CACHE MANAGEMENT</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_load_cache</span><span>(</span><span class="ͼt">self</span><span>):</span><br><span>        </span><span class="ͼn">try</span><span>:</span><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼt">os</span><span class="ͼn">.</span><span>path</span><span class="ͼn">.</span><span>exists(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache_path):</span><br><span>                </span><span class="ͼn">with</span><span> </span><span class="ͼt">open</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache_path, </span><span class="ͼr">"r"</span><span>) </span><span class="ͼn">as</span><span> </span><span class="ͼt">f</span><span>:</span><br><span>                    </span><span class="ͼn">return</span><span> </span><span class="ͼt">json</span><span class="ͼn">.</span><span>load(</span><span class="ͼt">f</span><span>)</span><br><span>        </span><span class="ͼn">except</span><span>:</span><br><span>            </span><span class="ͼn">pass</span><br><span>        </span><span class="ͼn">return</span><span> {}</span><br><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_save_cache</span><span>(</span><span class="ͼt">self</span><span>):</span><br><span>        </span><span class="ͼn">try</span><span>:</span><br><span>            </span><span class="ͼn">with</span><span> </span><span class="ͼt">open</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache_path, </span><span class="ͼr">"w"</span><span>) </span><span class="ͼn">as</span><span> </span><span class="ͼt">f</span><span>:</span><br><span>                </span><span class="ͼt">json</span><span class="ͼn">.</span><span>dump(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache, </span><span class="ͼt">f</span><span>)</span><br><span>        </span><span class="ͼn">except</span><span>:</span><br><span>            </span><span class="ͼn">pass</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># HASH INPUT</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_hash_input</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">indicators</span><span>, </span><span class="ͼt">prediction</span><span>):</span><br><br><span>        </span><span class="ͼt">payload</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">json</span><span class="ͼn">.</span><span>dumps({</span><br><span>            </span><span class="ͼr">"symbol"</span><span>: </span><span class="ͼt">symbol</span><span>,</span><br><span>            </span><span class="ͼr">"ind"</span><span>: </span><span class="ͼt">indicators</span><span>,</span><br><span>            </span><span class="ͼr">"pred"</span><span>: </span><span class="ͼt">prediction</span><br><span>        }, </span><span class="ͼt">sort_keys</span><span class="ͼn">=</span><span class="ͼq">True</span><span>)</span><br><br><span>        </span><span class="ͼn">return</span><span> </span><span class="ͼt">hashlib</span><span class="ͼn">.</span><span>md5(</span><span class="ͼt">payload</span><span class="ͼn">.</span><span>encode())</span><span class="ͼn">.</span><span>hexdigest()</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># REFLECTION MEMORY</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_get_reflection_notes</span><span>(</span><span class="ͼt">self</span><span>):</span><br><br><span>        </span><span class="ͼt">reflection_file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"src/logs/reflection_notes.txt"</span><br><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼt">os</span><span class="ͼn">.</span><span>path</span><span class="ͼn">.</span><span>exists(</span><span class="ͼt">reflection_file</span><span>):</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼr">""</span><br><br><span>        </span><span class="ͼn">try</span><span>:</span><br><span>            </span><span class="ͼn">with</span><span> </span><span class="ͼt">open</span><span>(</span><span class="ͼt">reflection_file</span><span>, </span><span class="ͼr">"r"</span><span>, </span><span class="ͼt">encoding</span><span class="ͼn">=</span><span class="ͼr">"utf-8"</span><span>) </span><span class="ͼn">as</span><span> </span><span class="ͼt">f</span><span>:</span><br><span>                </span><span class="ͼt">lines</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">f</span><span class="ͼn">.</span><span>readlines()[</span><span class="ͼn">-</span><span class="ͼq">20</span><span>:]</span><br><span>                </span><span class="ͼn">return</span><span> </span><span class="ͼr">""</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">lines</span><span>)</span><br><span>        </span><span class="ͼn">except</span><span>:</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼr">""</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># RISK SCORE</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_compute_risk_score</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">prediction</span><span>, </span><span class="ͼt">account_state</span><span>):</span><br><br><span>        </span><span class="ͼt">confidence</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">prediction</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"confidence"</span><span>, </span><span class="ͼq">0.5</span><span>)</span><br><br><span>        </span><span class="ͼt">open_pos</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">account_state</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"open_positions"</span><span>, </span><span class="ͼq">0</span><span>)</span><br><span>        </span><span class="ͼt">risk_ratio</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">account_state</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"risk_ratio"</span><span>, </span><span class="ͼq">0.0</span><span>)</span><br><br><span>        </span><span class="ͼt">risk_score</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼq">0</span><br><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">confidence</span><span> </span><span class="ͼn">&lt;</span><span> </span><span class="ͼq">0.6</span><span>:</span><br><span>            </span><span class="ͼt">risk_score</span><span> </span><span class="ͼn">+=</span><span> </span><span class="ͼq">2</span><br><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">open_pos</span><span> </span><span class="ͼn">&gt;</span><span> </span><span class="ͼq">5</span><span>:</span><br><span>            </span><span class="ͼt">risk_score</span><span> </span><span class="ͼn">+=</span><span> </span><span class="ͼq">2</span><br><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">risk_ratio</span><span> </span><span class="ͼn">&gt;</span><span> </span><span class="ͼq">0.3</span><span>:</span><br><span>            </span><span class="ͼt">risk_score</span><span> </span><span class="ͼn">+=</span><span> </span><span class="ͼq">3</span><br><br><span>        </span><span class="ͼn">return</span><span> </span><span class="ͼt">risk_score</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># GPT REASONING</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">explain_decision</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">indicators</span><span>, </span><span class="ͼt">prediction</span><span>, </span><span class="ͼt">account_state</span><span>):</span><br><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>client:</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼr">"⚠️ GPT client not initialized."</span><br><br><span>        </span><span class="ͼt">reflection</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_get_reflection_notes()</span><br><br><span>        </span><span class="ͼt">cache_key</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_hash_input(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">indicators</span><span>, </span><span class="ͼt">prediction</span><span>)</span><br><br><span>        </span><span class="ͼn">if</span><span> </span><span class="ͼt">cache_key</span><span> </span><span class="ͼn">in</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache:</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache[</span><span class="ͼt">cache_key</span><span>]</span><br><br><span>        </span><span class="ͼt">risk_score</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_compute_risk_score(</span><span class="ͼt">prediction</span><span>, </span><span class="ͼt">account_state</span><span>)</span><br><br><span>        </span><span class="ͼt">prompt</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">f"""</span><br><span class="ͼr">You are an AI trading analyst integrated into an automated system.</span><br><br><span class="ͼr">Reflection memory from past trades:</span><br><span>{</span><span class="ͼt">reflection</span><span>}</span><br><br><span class="ͼr">Analyze the following trading signal.</span><br><br><span class="ͼr">Symbol: </span><span>{</span><span class="ͼt">symbol</span><span>}</span><br><br><span class="ͼr">Indicators:</span><br><span>{</span><span class="ͼt">json</span><span class="ͼn">.</span><span>dumps(</span><span class="ͼt">indicators</span><span>, </span><span class="ͼt">indent</span><span class="ͼn">=</span><span class="ͼq">2</span><span>)}</span><br><br><span class="ͼr">Prediction:</span><br><span>{</span><span class="ͼt">json</span><span class="ͼn">.</span><span>dumps(</span><span class="ͼt">prediction</span><span>, </span><span class="ͼt">indent</span><span class="ͼn">=</span><span class="ͼq">2</span><span>)}</span><br><br><span class="ͼr">Account State:</span><br><span>{</span><span class="ͼt">json</span><span class="ͼn">.</span><span>dumps(</span><span class="ͼt">account_state</span><span>, </span><span class="ͼt">indent</span><span class="ͼn">=</span><span class="ͼq">2</span><span>)}</span><br><br><span class="ͼr">Risk Score: </span><span>{</span><span class="ͼt">risk_score</span><span>}</span><br><br><span class="ͼr">Provide a structured explanation including:</span><br><br><span class="ͼr">1. Market condition (trend / range / volatility)</span><br><span class="ͼr">2. Reasoning for BUY/SELL/HOLD decision</span><br><span class="ͼr">3. Key indicators influencing the decision</span><br><span class="ͼr">4. Short-term expectation</span><br><span class="ͼr">5. Risk evaluation</span><br><span class="ͼr">6. Suggested position sizing advice</span><br><span class="ͼr">7. Confidence interpretation</span><br><span class="ͼr">"""</span><br><br><span>        </span><span class="ͼt">t0</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">time</span><span class="ͼn">.</span><span>time()</span><br><br><span>        </span><span class="ͼn">try</span><span>:</span><br><br><span>            </span><span class="ͼt">response</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>client</span><span class="ͼn">.</span><span>chat</span><span class="ͼn">.</span><span>completions</span><span class="ͼn">.</span><span>create(</span><br><span>                </span><span class="ͼt">model</span><span class="ͼn">=</span><span class="ͼr">"gpt-4o-mini"</span><span>,</span><br><span>                </span><span class="ͼt">messages</span><span class="ͼn">=</span><span>[{</span><span class="ͼr">"role"</span><span>: </span><span class="ͼr">"user"</span><span>, </span><span class="ͼr">"content"</span><span>: </span><span class="ͼt">prompt</span><span>}],</span><br><span>                </span><span class="ͼt">temperature</span><span class="ͼn">=</span><span class="ͼq">0.35</span><span>,</span><br><span>                </span><span class="ͼt">max_tokens</span><span class="ͼn">=</span><span class="ͼq">350</span><br><span>            )</span><br><br><span>            </span><span class="ͼt">reasoning</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">response</span><span class="ͼn">.</span><span>choices[</span><span class="ͼq">0</span><span>]</span><span class="ͼn">.</span><span>message</span><span class="ͼn">.</span><span>content</span><span class="ͼn">.</span><span>strip()</span><br><br><span>            </span><span class="ͼt">latency</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">round</span><span>((</span><span class="ͼt">time</span><span class="ͼn">.</span><span>time() </span><span class="ͼn">-</span><span> </span><span class="ͼt">t0</span><span>) </span><span class="ͼn">*</span><span> </span><span class="ͼq">1000</span><span>, </span><span class="ͼq">2</span><span>)</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_log_reasoning(</span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">indicators</span><span>, </span><span class="ͼt">prediction</span><span>, </span><span class="ͼt">reasoning</span><span>, </span><span class="ͼt">latency</span><span>)</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>cache[</span><span class="ͼt">cache_key</span><span>] </span><span class="ͼn">=</span><span> </span><span class="ͼt">reasoning</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_save_cache()</span><br><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼt">reasoning</span><br><br><span>        </span><span class="ͼn">except</span><span> </span><span class="ͼt">Exception</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">e</span><span>:</span><br><br><span>            </span><span class="ͼt">err</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">f"⚠️ GPT reasoning failed: </span><span>{</span><span class="ͼt">e</span><span>}</span><span class="ͼr">"</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>error(</span><span class="ͼt">err</span><span>)</span><br><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼt">err</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># LOG REASONING</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_log_reasoning</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">indicators</span><span>, </span><span class="ͼt">prediction</span><span>, </span><span class="ͼt">reasoning</span><span>, </span><span class="ͼt">latency</span><span>):</span><br><br><span>        </span><span class="ͼt">entry</span><span> </span><span class="ͼn">=</span><span> {</span><br><span>            </span><span class="ͼr">"timestamp"</span><span>: </span><span class="ͼt">datetime</span><span class="ͼn">.</span><span>datetime</span><span class="ͼn">.</span><span>utcnow()</span><span class="ͼn">.</span><span>isoformat(),</span><br><span>            </span><span class="ͼr">"symbol"</span><span>: </span><span class="ͼt">symbol</span><span>,</span><br><span>            </span><span class="ͼr">"indicators"</span><span>: </span><span class="ͼt">indicators</span><span>,</span><br><span>            </span><span class="ͼr">"decision"</span><span>: </span><span class="ͼt">prediction</span><span>,</span><br><span>            </span><span class="ͼr">"reasoning"</span><span>: </span><span class="ͼt">reasoning</span><span>,</span><br><span>            </span><span class="ͼr">"latency_ms"</span><span>: </span><span class="ͼt">latency</span><br><span>        }</span><br><br><span>        </span><span class="ͼn">with</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_lock:</span><br><span>            </span><span class="ͼn">with</span><span> </span><span class="ͼt">open</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>log_path, </span><span class="ͼr">"a"</span><span>, </span><span class="ͼt">encoding</span><span class="ͼn">=</span><span class="ͼr">"utf-8"</span><span>) </span><span class="ͼn">as</span><span> </span><span class="ͼt">f</span><span>:</span><br><span>                </span><span class="ͼt">f</span><span class="ͼn">.</span><span>write(</span><span class="ͼt">json</span><span class="ͼn">.</span><span>dumps(</span><span class="ͼt">entry</span><span>) </span><span class="ͼn">+</span><span> </span><span class="ͼr">"</span><span class="ͼx">\n</span><span class="ͼr">"</span><span>)</span><br><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>info(</span><span class="ͼr">f"🧠 Reasoning logged for </span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># UPDATE TRADE OUTCOME</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">update_reasoning_outcome</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">trade_result</span><span>, </span><span class="ͼt">profit_pips</span><span>):</span><br><br><span>        </span><span class="ͼn">try</span><span>:</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼt">os</span><span class="ͼn">.</span><span>path</span><span class="ͼn">.</span><span>exists(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>log_path):</span><br><span>                </span><span class="ͼn">return</span><br><br><span>            </span><span class="ͼt">lines</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">open</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>log_path, </span><span class="ͼr">"r"</span><span>, </span><span class="ͼt">encoding</span><span class="ͼn">=</span><span class="ͼr">"utf-8"</span><span>)</span><span class="ͼn">.</span><span>read()</span><span class="ͼn">.</span><span>splitlines()</span><br><br><span>            </span><span class="ͼn">for</span><span> </span><span class="ͼt">i</span><span> </span><span class="ͼn">in</span><span> </span><span class="ͼt">reversed</span><span>(</span><span class="ͼt">range</span><span>(</span><span class="ͼt">len</span><span>(</span><span class="ͼt">lines</span><span>))):</span><br><br><span>                </span><span class="ͼt">entry</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">json</span><span class="ͼn">.</span><span>loads(</span><span class="ͼt">lines</span><span>[</span><span class="ͼt">i</span><span>])</span><br><br><span>                </span><span class="ͼn">if</span><span> </span><span class="ͼt">entry</span><span>[</span><span class="ͼr">"symbol"</span><span>] </span><span class="ͼn">==</span><span> </span><span class="ͼt">symbol</span><span> </span><span class="ͼn">and</span><span> </span><span class="ͼr">"outcome"</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼn">in</span><span> </span><span class="ͼt">entry</span><span>:</span><br><br><span>                    </span><span class="ͼt">entry</span><span>[</span><span class="ͼr">"outcome"</span><span>] </span><span class="ͼn">=</span><span> {</span><br><span>                        </span><span class="ͼr">"result"</span><span>: </span><span class="ͼr">"WIN"</span><span> </span><span class="ͼn">if</span><span> </span><span class="ͼt">profit_pips</span><span> </span><span class="ͼn">&gt;</span><span> </span><span class="ͼq">0</span><span> </span><span class="ͼn">else</span><span> </span><span class="ͼr">"LOSS"</span><span>,</span><br><span>                        </span><span class="ͼr">"profit_pips"</span><span>: </span><span class="ͼt">profit_pips</span><span>,</span><br><span>                        </span><span class="ͼr">"verified_at"</span><span>: </span><span class="ͼt">time</span><span class="ͼn">.</span><span>strftime(</span><span class="ͼr">"%Y-%m-%d %H:%M:%S"</span><span>)</span><br><span>                    }</span><br><br><span>                    </span><span class="ͼt">lines</span><span>[</span><span class="ͼt">i</span><span>] </span><span class="ͼn">=</span><span> </span><span class="ͼt">json</span><span class="ͼn">.</span><span>dumps(</span><span class="ͼt">entry</span><span>)</span><br><span>                    </span><span class="ͼn">break</span><br><br><span>            </span><span class="ͼn">with</span><span> </span><span class="ͼt">open</span><span>(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>log_path, </span><span class="ͼr">"w"</span><span>, </span><span class="ͼt">encoding</span><span class="ͼn">=</span><span class="ͼr">"utf-8"</span><span>) </span><span class="ͼn">as</span><span> </span><span class="ͼt">f</span><span>:</span><br><span>                </span><span class="ͼt">f</span><span class="ͼn">.</span><span>write(</span><span class="ͼr">"</span><span class="ͼx">\n</span><span class="ͼr">"</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">lines</span><span>))</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>info(</span><span class="ͼr">f"📊 Outcome updated for </span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>        </span><span class="ͼn">except</span><span> </span><span class="ͼt">Exception</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">e</span><span>:</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">f"⚠️ Failed to update outcome: </span><span>{</span><span class="ͼt">e</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼl"># PERFORMANCE STATS</span><br><span>    </span><span class="ͼl"># --------------------------------------------------------------</span><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">get_reasoning_stats</span><span>(</span><span class="ͼt">self</span><span>):</span><br><br><span>        </span><span class="ͼn">try</span><span>:</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼt">os</span><span class="ͼn">.</span><span>path</span><span class="ͼn">.</span><span>exists(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>log_path):</span><br><span>                </span><span class="ͼn">return</span><span> {}</span><br><br><span>            </span><span class="ͼt">df</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">pd</span><span class="ͼn">.</span><span>read_json(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>log_path, </span><span class="ͼt">lines</span><span class="ͼn">=</span><span class="ͼq">True</span><span>)</span><br><br><span>            </span><span class="ͼt">wins</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">len</span><span>(</span><span class="ͼt">df</span><span>[</span><span class="ͼt">df</span><span>[</span><span class="ͼr">"outcome"</span><span>]</span><span class="ͼn">.</span><span>apply(</span><span class="ͼn">lambda</span><span> </span><span class="ͼt">x</span><span>: </span><span class="ͼt">x</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"result"</span><span>) </span><span class="ͼn">==</span><span> </span><span class="ͼr">"WIN"</span><span> </span><span class="ͼn">if</span><span> </span><span class="ͼt">isinstance</span><span>(</span><span class="ͼt">x</span><span>, </span><span class="ͼt">dict</span><span>) </span><span class="ͼn">else</span><span> </span><span class="ͼq">False</span><span>)])</span><br><span>            </span><span class="ͼt">losses</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">len</span><span>(</span><span class="ͼt">df</span><span>[</span><span class="ͼt">df</span><span>[</span><span class="ͼr">"outcome"</span><span>]</span><span class="ͼn">.</span><span>apply(</span><span class="ͼn">lambda</span><span> </span><span class="ͼt">x</span><span>: </span><span class="ͼt">x</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"result"</span><span>) </span><span class="ͼn">==</span><span> </span><span class="ͼr">"LOSS"</span><span> </span><span class="ͼn">if</span><span> </span><span class="ͼt">isinstance</span><span>(</span><span class="ͼt">x</span><span>, </span><span class="ͼt">dict</span><span>) </span><span class="ͼn">else</span><span> </span><span class="ͼq">False</span><span>)])</span><br><br><span>            </span><span class="ͼt">total</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">wins</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">losses</span><br><br><span>            </span><span class="ͼt">win_rate</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">wins</span><span> </span><span class="ͼn">/</span><span> </span><span class="ͼt">total</span><span> </span><span class="ͼn">if</span><span> </span><span class="ͼt">total</span><span> </span><span class="ͼn">&gt;</span><span> </span><span class="ͼq">0</span><span> </span><span class="ͼn">else</span><span> </span><span class="ͼq">0</span><br><br><span>            </span><span class="ͼn">return</span><span> {</span><br><span>                </span><span class="ͼr">"total_trades"</span><span>: </span><span class="ͼt">total</span><span>,</span><br><span>                </span><span class="ͼr">"wins"</span><span>: </span><span class="ͼt">wins</span><span>,</span><br><span>                </span><span class="ͼr">"losses"</span><span>: </span><span class="ͼt">losses</span><span>,</span><br><span>                </span><span class="ͼr">"win_rate"</span><span>: </span><span class="ͼt">round</span><span>(</span><span class="ͼt">win_rate</span><span>, </span><span class="ͼq">3</span><span>)</span><br><span>            }</span><br><br><span>        </span><span class="ͼn">except</span><span>:</span><br><span>            </span><span class="ͼn">return</span><span> {}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
