" class="-ms-0.5 icon"><use href="/cdn/assets/sprites-core-ni7q5mnh.svg#6ef7a4" fill="currentColor"></use></svg>Run</div></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼl"># core/multi_symbol_orchestrator.py</span><br><br><span class="ͼn">import</span><span> </span><span class="ͼt">asyncio</span><br><span class="ͼn">from</span><span> </span><span class="ͼt">core</span><span class="ͼn">.</span><span class="ͼt">symbol_worker</span><span> </span><span class="ͼn">import</span><span> </span><span class="ͼt">SymbolWorker</span><br><br><br><span class="ͼn">class</span><span> </span><span class="ͼs">MultiSymbolOrchestrator</span><span>:</span><br><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">__init__</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">broker</span><span>, </span><span class="ͼt">strategy</span><span>, </span><span class="ͼt">execution_manager</span><span>):</span><br><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>broker </span><span class="ͼn">=</span><span> </span><span class="ͼt">broker</span><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>strategy </span><span class="ͼn">=</span><span> </span><span class="ͼt">strategy</span><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>execution_manager </span><span class="ͼn">=</span><span> </span><span class="ͼt">execution_manager</span><br><br><span>        </span><span class="ͼt">self</span><span class="ͼn">.</span><span>workers </span><span class="ͼn">=</span><span> []</span><br><br><span>    </span><span class="ͼn">async</span><span> </span><span class="ͼn">def</span><span> </span><span class="ͼt">start</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbols</span><span>):</span><br><br><span>        </span><span class="ͼt">tasks</span><span> </span><span class="ͼn">=</span><span> []</span><br><br><span>        </span><span class="ͼn">for</span><span> </span><span class="ͼt">symbol</span><span> </span><span class="ͼn">in</span><span> </span><span class="ͼt">symbols</span><span>:</span><br><br><span>            </span><span class="ͼt">worker</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">SymbolWorker</span><span>(</span><br><span>                </span><span class="ͼt">symbol</span><span>,</span><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>broker,</span><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>strategy,</span><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>execution_manager</span><br><span>            )</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>workers</span><span class="ͼn">.</span><span>append(</span><span class="ͼt">worker</span><span>)</span><br><br><span>            </span><span class="ͼt">tasks</span><span class="ͼn">.</span><span>append(</span><br><span>                </span><span class="ͼt">asyncio</span><span class="ͼn">.</span><span>create_task(</span><span class="ͼt">worker</span><span class="ͼn">.</span><span>run())</span><br><span>            )</span><br><br><span>        </span><span class="ͼn">await</span><span> </span><span class="ͼt">asyncio</span><span class="ͼn">.</span><span>gather(</span><span class="ͼn">*</span><span class="ͼt">tasks</span><span>)</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
