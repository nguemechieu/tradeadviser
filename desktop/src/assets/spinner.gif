/span><span>error(</span><span class="ͼr">f"❌ Auto-train failed: </span><span>{</span><span class="ͼt">e</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>    </span><span class="ͼn">def</span><span> </span><span class="ͼt">_train</span><span>(</span><span class="ͼt">self</span><span>, </span><span class="ͼt">symbol</span><span>, </span><span class="ͼt">signal_file</span><span>, </span><span class="ͼt">candle_file</span><span>, </span><span class="ͼt">force</span><span class="ͼn">=</span><span class="ͼq">True</span><span>):</span><br><br><span>        </span><span class="ͼn">try</span><span>:</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>info(</span><span class="ͼr">f"🔁 Retraining model for </span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">..."</span><span>)</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>trainer</span><span class="ͼn">.</span><span>train_and_save_model(</span><br><span>                </span><span class="ͼt">symbol</span><span>,</span><br><span>                </span><span class="ͼt">signal_file</span><span>,</span><br><span>                </span><span class="ͼt">candle_file</span><span>,</span><br><span>                </span><span class="ͼt">MODEL_PATH</span><span>,</span><br><span>                </span><span class="ͼt">SCALER_PATH</span><br><span>            )</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>_lazy_load(</span><span class="ͼt">force</span><span class="ͼn">=</span><span class="ͼq">True</span><span>)</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>low_confidence_count </span><span class="ͼn">=</span><span> </span><span class="ͼq">0</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>info(</span><span class="ͼr">f"✅ Retraining complete for </span><span>{</span><span class="ͼt">symbol</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>        </span><span class="ͼn">except</span><span> </span><span class="ͼt">Exception</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">e</span><span>:</span><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">f"❌ Retrain error: </span><span>{</span><span class="ͼt">e</span><span>}</span><span class="ͼr">"</span><span>)</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
