var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">[build-system]</span></span><br><span>requires = <span data-placeholder-token="true" class="text-token-text-primary cursor-text rounded-sm" style="background-color: color-mix(in srgb, var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">["setuptools&gt;=68", "wheel"]</span></span><br><span>build-backend = "setuptools.build_meta"</span></p><p><span><span data-placeholder-token="true" class="text-token-text-primary cursor-text rounded-sm" style="background-color: color-mix(in srgb, var(--theme-user-selection-bg, var(--selection)) 30%, transparent); padding-top: 4px; padding-bottom: 4px;">[project]</span></span><br><span>name = "mt4-predict-server"</span><br><span>version = "0.1.0"</span><br><span>description = "AI prediction server for MetaTrader 4 with TensorFlow and PySide GUI"</span><br><span>authors = [</span><br><span>{name = "Noel Martial Nguemechieu"}</span><br><span>]</span><br><span>readme = "README.md"</span><br><span>requires-python = "&gt;=3.10,&lt;3.12"</span></p><p><span>dependencies = [</span><br><span>"tensorflow==2.15",</span><br><span>"numpy==1.26.4",</span><br><span>"pandas&gt;=2.0",</span><br><span>"scikit-learn&gt;=1.3",</span><br><span>"matplotlib&gt;=3.8",</span></p><pre dir="ltr"><code dir="ltr"><span>"PySide6&gt;=6.6",
