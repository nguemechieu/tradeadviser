/span><span> </span><span class="ͼn">not</span><span> </span><span class="ͼt">api_key</span><span>:</span><br><br><span>        </span><span class="ͼt">QMessageBox</span><span class="ͼn">.</span><span>warning(</span><br><span>            </span><span class="ͼt">self</span><span>,</span><br><span>            </span><span class="ͼr">"Missing Credentials"</span><span>,</span><br><span>            </span><span class="ͼr">"API credentials required."</span><br><span>        )</span><br><br><span>        </span><span class="ͼn">return</span><br><br><span>    </span><span class="ͼt">broker_config</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">BrokerConfig</span><span>(</span><br><span>        </span><span class="ͼt">type</span><span class="ͼn">=</span><span class="ͼt">self</span><span class="ͼn">.</span><span>exchange_type_box</span><span class="ͼn">.</span><span>currentText(),</span><br><span>        </span><span class="ͼt">exchange</span><span class="ͼn">=</span><span class="ͼt">exchange</span><span>,</span><br><span>        </span><span class="ͼt">mode</span><span class="ͼn">=</span><span class="ͼt">self</span><span class="ͼn">.</span><span>mode_box</span><span class="ͼn">.</span><span>currentText(),</span><br><span>        </span><span class="ͼt">api_key</span><span class="ͼn">=</span><span class="ͼt">api_key</span><span>,</span><br><span>        </span><span class="ͼt">secret</span><span class="ͼn">=</span><span class="ͼt">secret</span><br><span>    )</span><br><br><span>    </span><span class="ͼt">self</span><span class="ͼn">.</span><span>broker </span><span class="ͼn">=</span><span> </span><span class="ͼt">BrokerFactory</span><span class="ͼn">.</span><span>create(</span><span class="ͼt">broker_config</span><span>)</span><br><br><span>    </span><span class="ͼt">config</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">AppConfig</span><span>(</span><br><span>        </span><span class="ͼt">broker</span><span class=