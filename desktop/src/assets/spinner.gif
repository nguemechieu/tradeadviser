>        </span><span class="ͼn">try</span><span>:</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>trading_system:</span><br><br><span>                </span><span class="ͼn">await</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>trading_system</span><span class="ͼn">.</span><span>stop()</span><br><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>trading_system </span><span class="ͼn">=</span><span> </span><span class="ͼq">None</span><br><br><span>            </span><span class="ͼn">if</span><span> </span><span class="ͼt">self</span><span class="ͼn">.</span><span>terminal:</span><br><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>stack</span><span class="ͼn">.</span><span>removeWidget(</span><span class="ͼt">self</span><span class="ͼn">.</span><span>terminal)</span><br><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>terminal</span><span class="ͼn">.</span><span>deleteLater()</span><br><br><span>                </span><span class="ͼt">self</span><span class="ͼn">.</span><span>terminal </span><span class="ͼn">=</span><span> </span><span class="ͼq">None</span><br><br><span>        </span><span class="ͼn">except</span><span> </span><span class="ͼt">Exception</span><span> </span><span class="ͼn">as</span><span> </span><span class="ͼt">e</span><span>:</span><br><br><span>            </span><span class="ͼt">self</span><span class="ͼn">.</span><span>logger</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">f"Cleanup error: </span><span>{</span><span class="ͼt">e</span><span>}</span><span class="ͼr">"</span><span>)</span><br><br><span>    </span><span class="ͼl"># =========================================================</span><br><span>    </span><span class="ͼl"># LOGOUT</span><br><span>    </span><span class="ͼ