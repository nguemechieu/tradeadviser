# Production stage
FROM node:18-alpine

WORKDIR /app/frontend

# Set security-focused environment variables
ENV NODE_ENV=development \
    NODE_OPTIONS="--no-deprecation" \
    DISABLE_TELEMETRY=1

# Create non-root user FIRST before copying any files
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

# Copy package files
COPY app/frontend/package*.json ./

# Install all dependencies (needed for dev server with vite)
RUN npm ci

# Copy built application from builder
COPY --from=builder /app/frontend/dist ./dist
COPY --from=builder /app/frontend/src ./src

# Set proper file permissions with user that now exists
RUN chown -R nodejs:nodejs /app/frontend && \
    chmod -R 755 /app/frontend

# Switch to non-root user
USER nodejs

# Expose port for development server
EXPOSE 5173

# Health check - give time for proper initialization
HEALTHCHECK --interval=30s --timeout=10s --start-period=45s --retries=5 \
    CMD wget --quiet --tries=1 --spider http://127.0.0.1:5173/ || exit 1

# Development mode with security considerations
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
=======
# Install dependencies with legacy peer deps support
RUN npm ci --legacy-peer-deps

# Copy TypeScript configuration
COPY frontend/tsconfig.json ./
COPY frontend/tsconfig.node.json ./
COPY frontend/vite.config.js ./

# Copy source code
COPY frontend/src ./src
COPY frontend/public ./public
COPY frontend/index.html ./

# Type check and build the app
RUN npm run type-check && npm run build

# Stage 2: Serve with Nginx
FROM nginx:alpine

# Copy nginx config for React SPA
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built app from builder stage
COPY --from=builder /build/dist /usr/share/nginx/html

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost/ || exit 1

# Start Nginx
CMD ["nginx", "-g", "daemon off;"]
