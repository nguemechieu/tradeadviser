# ============================================
# TradeAdviser Platform Environment Variables
# ============================================

# Database Configuration
DB_PASSWORD=tradeadviser_dev_password
DB_USER=tradeadviser
DB_NAME=tradeadviser
DATABASE_URL=postgresql+asyncpg://tradeadviser:tradeadviser_dev_password@database:5432/tradeadviser

# JWT and Security
JWT_SECRET_KEY=your-secret-key-change-in-production-with-long-random-string

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost,http://localhost:8000

# Control Tower & Monitoring
ENABLE_CONTROL_TOWER=true
CONTROL_TOWER_UPDATE_INTERVAL=2

# License Management
ENABLE_LICENSE_MANAGEMENT=true
TRIAL_DAYS=30

# ============================================
# Payment Processing Configuration
# ============================================

# Stripe Configuration (https://dashboard.stripe.com)
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=usd

# PayPal Configuration (https://developer.paypal.com)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Coinbase Commerce Configuration (https://commerce.coinbase.com)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_WEBHOOK_SECRET=your_coinbase_webhook_secret_here

# ============================================
# Email Configuration
# ============================================

# SMTP Configuration for Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_NAME=TradeAdviser
SMTP_FROM_EMAIL=noreply@tradeadviser.io
SMTP_USE_TLS=true

# Alternative: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key

# Alternative: Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASSWORD=your_mailgun_api_key

# ============================================
# Application Environment
# ============================================

ENV=production
DEBUG=false
LOG_LEVEL=info

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8000

# ============================================
# Usage Instructions
# ============================================
# 1. Copy this file to .env
# 2. Update all placeholder values with your actual configuration
# 3. For production, use strong JWT_SECRET_KEY and secure passwords
# 4. For Stripe/PayPal/Coinbase, get keys from their respective dashboards
# 5. For SMTP, use an app-specific password (not your main email password)
# 6. Never commit .env file to version control

