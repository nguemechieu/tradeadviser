# Backend Dockerfile for TradeAdviser
# Build: docker build -f docker/Dockerfile.backend -t tradeadviser-backend .
# Run: docker run -p 8000:8000 -e DATABASE_URL=sqlite:///./test.db tradeadviser-backend

FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies
