# TradeAdviser Environment Configuration
# Copy this file to .env.local and update with your settings

# ============================================================
# Application Configuration
# ============================================================
APP_NAME=TradeAdviser
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
FRONTEND_PORT=5173
FRONTEND_DIST=./frontend/dist

# ============================================================
# Company Information
# ============================================================
COMPANY_NAME=Sopotek Inc
COMPANY_WEBSITE=https://sopotek.com
APP_WEBSITE=https://tradeadviser.org
SUPPORT_EMAIL=support@sopotek.com

# ============================================================
# Database Configuration
# ============================================================
# Development (SQLite):
DATABASE_URL=sqlite:///./tradeadviser.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/tradeadviser
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=10
# DATABASE_POOL_RECYCLE=3600

# ============================================================
# JWT Authentication
# ============================================================
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# CORS Settings
# ============================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8000,http://localhost:3000
ALLOW_CREDENTIALS=true

# ============================================================
# OAuth Configuration (Optional)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================
# Email Configuration (For Notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@tradeadviser.org
SMTP_FROM_NAME=TradeAdviser

# ============================================================
# Security Configuration
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15

# ============================================================
# Logging Configuration
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/tradeadviser.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================
# Cache Configuration
# ============================================================
CACHE_BACKEND=memory
# For Redis cache:
# CACHE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# Message Queue Configuration (Optional)
# ============================================================
KAFKA_ENABLED=false
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_PREFIX=tradeadviser
KAFKA_CONSUMER_GROUP=tradeadviser-app

# ============================================================
# Feature Flags
# ============================================================
FEATURE_KAFKA_ENABLED=false
FEATURE_ADVANCED_AGENTS_ENABLED=true
FEATURE_RISK_ALERTS_ENABLED=true
FEATURE_PERFORMANCE_AUDIT_ENABLED=true
FEATURE_LICENSE_CHECK_ENABLED=true

# ============================================================
# Trading Configuration
# ============================================================
TRADING_DEFAULT_SLIPPAGE=0.001
TRADING_MAX_POSITION_SIZE=100000
TRADING_MIN_POSITION_SIZE=10
TRADING_EXECUTION_TIMEOUT_SECONDS=30

# ============================================================
# Risk Management
# ============================================================
RISK_VAR_CONFIDENCE_LEVEL=0.95
RISK_SHARPE_RATIO_TARGET=1.5
RISK_MAX_DRAWDOWN_PERCENT=20
RISK_ALERT_EMAIL_ENABLED=true

# ============================================================
# AI Agent Configuration
# ============================================================
AGENT_REGIME_ENABLED=true
AGENT_FEEDBACK_ENABLED=true
AGENT_DECISION_TIMEOUT_SECONDS=10
AGENT_MODEL_PATH=models/trading_model.pkl

# ============================================================
# External Services Integration
# ============================================================
MARKET_DATA_PROVIDER=alpha_vantage
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=

# ============================================================
# Monitoring & Observability
# ============================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Application Insights (Azure)
# APPLICATION_INSIGHTS_CONNECTION_STRING=

# ============================================================
# Database Backup
# ============================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=backups/

# ============================================================
# License Management
# ============================================================
LICENSE_CHECK_ENABLED=true
LICENSE_KEY=
LICENSE_EXPIRATION_WARNING_DAYS=30

# ============================================================
# API Configuration
# ============================================================
API_TITLE=TradeAdviser API
API_VERSION=1.0.0
API_DESCRIPTION=Intelligent Trading Advisory Platform
API_TERMS_OF_SERVICE=https://tradeadviser.org/terms
API_CONTACT_EMAIL=api@sopotek.com

# ============================================================
# Performance Tuning
# ============================================================
WORKER_THREADS=4
REQUEST_TIMEOUT_SECONDS=30
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# ============================================================
# Development Tools
# ============================================================
ENABLE_SWAGGER_DOCS=true
ENABLE_REDOC_DOCS=true
ENABLE_OPENAPI_SCHEMA=true

# ============================================================
# Deployment Environment
# ============================================================
# Options: development, staging, production
ENVIRONMENT=development

# ============================================================
# Notes
# ============================================================
# 1. NEVER commit .env or .env.local to git
# 2. Use .env.example as a template for new deployments
# 3. Keep sensitive values in environment variables or secrets manager
# 4. Update CORS allowed origins for your specific domain
# 5. Change JWT_SECRET_KEY for production
# 6. For production, use strong, randomly generated secrets
# 7. Configure proper database credentials
# 8. Set up email credentials if using email notifications
# 9. Enable monitoring and logging in production
# 10. Review all security settings before deployment
